<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KIOSK Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body style="background: var(--bg);">
  <div class="ipad-frame">
    <div class="ipad-notch"></div>

    <header class="site-header" style="margin-bottom:32px;">
      <div class="site-title">
        <img src="/logo.png" alt="KIOSK" class="site-logo">
        KIOSK
      </div>
      <nav class="site-nav">
        <a href="/">Angebote</a>
        <a href="/login">Einloggen</a>
        <a href="/register">Registrieren</a>
        <a href="/admin">&#9881; Broker</a>
      </nav>
    </header>

    <div class="form-container">
      <div class="form-title">Zugang</div>

      <% if (banned) { %>
        <div class="alert alert-error">Zugang dauerhaft verweigert.</div>
      <% } %>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/login" autocomplete="off">
        <div class="form-group">
          <label>Zugangscode (8 Ziffern)</label>
          <input type="text"
                 name="code"
                 maxlength="8"
                 placeholder="&#9632;&#9632;&#9632;&#9632;&#9632;&#9632;&#9632;&#9632;"
                 inputmode="numeric"
                 pattern="\d{8}"
                 autocomplete="off"
                 autofocus>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Eintreten</button>
      </form>

      <p class="form-footer-link">
        Kein Code? <a href="/register">Registrieren</a>
      </p>
    </div>

    <div class="ipad-home"></div>
  </div>
</body>
</html>
